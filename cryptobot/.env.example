# ============================================================
# CRYPTOBOT - Variables d'environnement
# ============================================================
# IMPORTANT : Renommer ce fichier en ".env" et remplir les valeurs.
# Ne jamais committer le fichier .env dans git.

# ── Binance API ──────────────────────────────────────────────
# Créer depuis : Binance > Mon Compte > Gestion API
# Droits requis : Spot Trading UNIQUEMENT. Jamais de droits retrait.
BINANCE_API_KEY=votre_cle_api_binance
BINANCE_API_SECRET=votre_secret_api_binance

# ── Freqtrade - Compartiment B (port 8080) ───────────────────
FREQTRADE_UI_USER=admin
FREQTRADE_UI_PASSWORD=ChangezCeMotDePasseAbs0lument!
FREQTRADE_JWT_SECRET=generez_une_chaine_aleatoire_de_32_chars_ici
FREQTRADE_WS_TOKEN=generez_un_autre_token_aleatoire_ici

# ── Freqtrade - Compartiment A (port 8081) ───────────────────
FREQTRADE_JWT_SECRET_A=generez_encore_une_autre_chaine_32_chars
FREQTRADE_WS_TOKEN_A=generez_un_autre_token_pour_compartiment_a

# ── Notifications (optionnel mais recommandé) ────────────────
# Telegram : créer un bot via @BotFather sur Telegram
TELEGRAM_TOKEN=votre_token_telegram_bot
TELEGRAM_CHAT_ID=votre_chat_id_telegram

# ── Claude API (pour les rapports) ───────────────────────────
# Créer depuis : console.anthropic.com
ANTHROPIC_API_KEY=votre_cle_api_anthropic

# ── Google Sheets (pour les logs) ───────────────────────────
# ID de votre feuille Google Sheets (dans l'URL)
GOOGLE_SHEETS_ID=votre_id_google_sheets

# ── n8n ──────────────────────────────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=ChangezCeMotDePasseAussi!
N8N_HOST=localhost
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678

# ── Email (pour les rapports) ────────────────────────────────
# Utiliser un compte Gmail avec mot de passe d'application
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_application_gmail
REPORT_RECIPIENT_EMAIL=yd@kunda.io
